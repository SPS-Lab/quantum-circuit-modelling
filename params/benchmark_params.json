{
  "parameter_notes": {
    "static_benchmark.duffing_model.transmon_spectral_extraction.ncut": "Used only when static_benchmark.duffing_model.calibration_mode is 'fixed' or 'per-flux'. Ignored for 'analytic-per-flux'.",
    "static_benchmark.duffing_model.transmon_spectral_extraction.truncated_dim": "Used only when static_benchmark.duffing_model.calibration_mode is 'fixed' or 'per-flux'. Ignored for 'analytic-per-flux'.",
    "truncation_benchmark.duffing_ncut_values": "Used only when truncation_benchmark.duffing_calibration_mode is 'fixed' or 'per-flux'. Not used for 'analytic-per-flux'.",
    "truncation_benchmark.duffing_truncated_dim": "Used only when truncation_benchmark.duffing_calibration_mode is 'fixed' or 'per-flux'. Not used for 'analytic-per-flux'.",
    "cz_benchmark.scan_dt_ns": "Used only when cz_benchmark.enable_hold_time_scan is true.",
    "cz_benchmark.scan_max_hold_ns": "Used only when cz_benchmark.enable_hold_time_scan is true.",
    "cz_benchmark.scan_leakage_penalty": "Used only when cz_benchmark.enable_hold_time_scan is true."
  },
  "run_all_benchmark_params": {
    "shared_static_cz_leakage_flow_truncation": {
      "static_benchmark": {
        "flux_sweep": {
          "start": 0.0,
          "stop": 1.0,
          "num_points": 61
        },
        "flux_control": {
          "sweep_target": "q2"
        },
        "coupler_frequency": {
          "wc0": 6.902,
          "amplitude": 0.0
        },
        "dressed_subspace": {
          "n_candidate_states": 20,
          "selection_mode": "bare"
        },
        "duffing_model": {
          "transmon_spectral_extraction": {
            "ncut": 60,
            "truncated_dim": 12
          },
          "hilbert_truncation": {
            "nlevels_qubit": 3,
            "nlevels_coupler": 3
          },
          "coupler_anharmonicity": 0.0,
          "calibration_mode": "analytic-per-flux"
        },
        "circuit_model": {
          "hilbert_truncation": {
            "q1_truncated_dim": 5,
            "q2_truncated_dim": 5,
            "c_truncated_dim": 6
          },
          "interaction_validity_check": true
        }
      }
    },
    "shared_static_and_cz": {
      "static_benchmark": {
        "effective_model": {
          "derivation_source": "circuit",
          "fit_basis": "single-harmonic"
        }
      }
    },
    "static_only": {
      "static_benchmark": {
        "regime_thresholds": {
          "idle_ratio": 6.0,
          "near_ratio": 2.0
        },
        "outputs": {
          "figure": "results/model_comparison_static.pdf"
        }
      }
    },
    "truncation_only": {
      "truncation_benchmark": {
        "fixed_flux": 0.000001,
        "duffing_ncut_values": [2, 3, 4, 5, 6, 7, 8, 15, 20],
        "duffing_truncated_dim": 40,
        "lowest_excited_levels_to_plot": 12,
        "circuit_reference_ncut": 120,
        "duffing_calibration_mode": "per-flux",
        "outputs": {
          "figure": "results/model_comparison_truncation_static_metrics.pdf"
        }
      }
    },
    "cz_only": {
      "cz_benchmark": {
        "total_time_ns": 10.0,
        "ramp_time_ns": 2.0,
        "dt_ns": 0.5,
        "enable_hold_time_scan": true,
        "scan_dt_ns": 10.0,
        "scan_max_hold_ns": 70.0,
        "scan_leakage_penalty": 0.25,
        "outputs": {
          "figure": "results/model_comparison_cz_dynamics.pdf"
        }
      }
    },
    "leakage_flow_only": {
      "leakage_flow_benchmark": {
        "total_time_ns": 8.0,
        "ramp_time_ns": 2.0,
        "dt_ns": 0.02,
        "population_min_average": 0.0001,
        "transition_min_integrated_abs": 0.0001,
        "max_population_rows": 12,
        "max_transition_rows": 12,
        "outputs": {
          "figure": "results/model_comparison_leakage_flow.pdf"
        }
      }
    }
  },
  "leakage_benchmark": {
    "total_time_ns": 20.0,
    "ramp_time_ns": 8.0,
    "dt_ns": 0.02,
    "top_destination_rows": 5
  },
  "state_to_state_leakage_benchmark": {
    "total_time_ns": 8.0,
    "ramp_time_ns": 2.0,
    "dt_ns": 0.02,
    "top_transition_rows": 6
  }
}
